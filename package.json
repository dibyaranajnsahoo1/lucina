{
  "name": "lucina-egg-bank",
  "version": "1.0.0",
  "description": "Lucina Egg Bank - Full Stack MERN Application",
  "scripts": {
    "install:all": "cd backend && npm install && cd ../frontend && npm install && cd ../admin && npm install",
    "seed": "cd backend && npm run seed",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:admin": "cd admin && npm run dev",
    "dev": "npm-run-all --parallel dev:backend dev:frontend dev:admin",
    "build:frontend": "cd frontend && npm run build",
    "build:admin": "cd admin && npm run build"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
